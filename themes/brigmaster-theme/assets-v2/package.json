{
  "name": "brigmaster-theme-assets-v2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run sprite && vite build",
    "preview": "vite preview",
    "sprite": "node scripts/build-sprite.mjs",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:js": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.{scss,js,html}\""
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "sass-embedded": "^1.80.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-order": "^6.0.4",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3"
  }
}
