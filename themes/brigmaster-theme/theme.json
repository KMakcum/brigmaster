{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "page-background", "name": "Page Background", "color": "#E8EEF4" },
        { "slug": "surface", "name": "Surface", "color": "#FFFFFF" },
        { "slug": "surface-elevated", "name": "Surface Elevated", "color": "#F4F7FA" },
        { "slug": "text-primary", "name": "Text Primary", "color": "#1C2430" },
        { "slug": "text-secondary", "name": "Text Secondary", "color": "#4A5568" },
        { "slug": "border", "name": "Border", "color": "#C5D0DC" },
        { "slug": "border-subtle", "name": "Border Subtle", "color": "#D8E0E8" },
        { "slug": "accent", "name": "Accent", "color": "#5B7C99" },
        { "slug": "accent-hover", "name": "Accent Hover", "color": "#4A6578" },
        { "slug": "accent-contrast", "name": "Accent Contrast", "color": "#FFFFFF" },
        { "slug": "info-bg", "name": "Info Background", "color": "#E8EEF4" },
        { "slug": "danger", "name": "Danger", "color": "#9B4A44" },
        { "slug": "danger-bg", "name": "Danger Background", "color": "#F7EBEA" },
        { "slug": "danger-border", "name": "Danger Border", "color": "#D4A5A0" },
        { "slug": "success", "name": "Success", "color": "#4A6B55" },
        { "slug": "success-bg", "name": "Success Background", "color": "#EAF3EC" },
        { "slug": "success-border", "name": "Success Border", "color": "#A8C9B0" },
        { "slug": "warning", "name": "Warning", "color": "#8A6B3D" },
        { "slug": "warning-bg", "name": "Warning Background", "color": "#F8F1E4" },
        { "slug": "warning-border", "name": "Warning Border", "color": "#D9C49A" },
        { "slug": "hero-dark", "name": "Hero Dark", "color": "#1E2430" },
        { "slug": "hero-text", "name": "Hero Text", "color": "#F6F7F9" },
        { "slug": "hero-muted", "name": "Hero Muted", "color": "#B8C0CC" }
      ]
    },
    "custom": {
      "container": {
        "content": "min(100% - 32px, 1120px)",
        "wide": "min(100% - 32px, 1200px)"
      },
      "motion": {
        "duration": "0.22s",
        "durationSlow": "0.35s",
        "ease": "cubic-bezier(0.4, 0, 0.2, 1)",
        "easeOut": "cubic-bezier(0, 0, 0.2, 1)"
      },
      "radius": {
        "xs": "6px",
        "sm": "8px",
        "md": "12px",
        "pill": "999px"
      },
      "shadow": {
        "card": "0 1px 2px rgba(28, 36, 48, 0.06)"
      },
      "focus": {
        "ring": "rgba(91, 124, 153, 0.35)"
      }
    },
    "layout": {
      "contentSize": "1120px",
      "wideSize": "1200px"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "spacingScale": {
        "steps": 8,
        "mediumStep": 1.25,
        "unit": "rem"
      },
      "spacingSizes": [
        { "slug": "2xs", "name": "2XS", "size": "0.5rem" },
        { "slug": "xs", "name": "XS", "size": "0.75rem" },
        { "slug": "sm", "name": "SM", "size": "1rem" },
        { "slug": "md", "name": "MD", "size": "1.5rem" },
        { "slug": "lg", "name": "LG", "size": "2rem" },
        { "slug": "xl", "name": "XL", "size": "2.5rem" },
        { "slug": "2xl", "name": "2XL", "size": "3rem" },
        { "slug": "3xl", "name": "3XL", "size": "4rem" },
        { "slug": "4xl", "name": "4XL", "size": "6rem" }
      ],
      "units": ["px", "rem", "em", "vw", "vh", "%"]
    },
    "typography": {
      "customFontSize": true,
      "customLineHeight": true,
      "fontFamilies": [
        {
          "fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif",
          "name": "Constructly Sans",
          "slug": "constructly-sans"
        }
      ],
      "fontSizes": [
        { "slug": "caption", "name": "Caption", "size": "0.8125rem" },
        { "slug": "label", "name": "Label", "size": "0.875rem" },
        { "slug": "sub", "name": "Sub Label", "size": "0.85rem" },
        { "slug": "body", "name": "Body", "size": "1rem" },
        { "slug": "lead", "name": "Lead", "size": "0.9rem" },
        { "slug": "card-title", "name": "Card Title", "size": "1.25rem" },
        { "slug": "section-title", "name": "Section Title", "size": "1.25rem" },
        { "slug": "hero-title", "name": "Hero Title", "size": "1.5rem" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--page-background)",
      "text": "var(--wp--preset--color--text-primary)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--constructly-sans)",
      "fontSize": "var(--wp--preset--font-size--body)",
      "lineHeight": "1.5"
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "var(--wp--custom--radius--sm)"
        },
        "spacing": {
          "padding": {
            "top": "10px",
            "right": "18px",
            "bottom": "10px",
            "left": "18px"
          }
        },
        "typography": {
          "fontWeight": "600",
          "fontSize": "0.875rem",
          "lineHeight": "1.2"
        }
      },
      "core/heading": {
        "color": {
          "text": "var(--wp--preset--color--text-primary)"
        },
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "core/paragraph": {
        "color": {
          "text": "var(--wp--preset--color--text-primary)"
        }
      },
      "core/table": {
        "border": {
          "color": "var(--wp--preset--color--border)"
        }
      }
    },
    "elements": {
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--accent-contrast)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        },
        "typography": {
          "fontWeight": "600",
          "textDecoration": "underline"
        }
      }
    }
  }
}
